set_input_transition -min 0.5  [get_ports {x[2]}]
set_input_transition -max 0.5  [get_ports {x[1]}]
set_input_transition -min 0.5  [get_ports {x[1]}]
set_input_transition -max 0.5  [get_ports {x[0]}]
set_input_transition -min 0.5  [get_ports {x[0]}]
set_input_transition -max 0.5  [get_ports clk]
